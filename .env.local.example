# ── 数据库 ────────────────────────────────────────────────
DATABASE_URL="file:./public/workspace/database.db"

# 官方文档：
# https://api-docs.deepseek.com/
# https://api-docs.deepseek.com/quick_start/pricing
# ── 大脑：剧本与分镜逻辑（DeepSeek V4 Pro）─────────────────
DEEPSEEK_API_KEY="sk-ff5d1c3d6ff146b6bb23c365f8588e41"
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
DEEPSEEK_MODEL="deepseek-v4-pro"

# 视觉质检 Agent 使用的模型（支持图片输入；留空则回退使用 DEEPSEEK_MODEL）
# VISION_QA_MODEL="deepseek-chat"

# 官方文档：
# https://www.volcengine.com/docs/6492/2221472
# https://www.volcengine.com/docs/6492/2172373
# ── 美术：图片生成与角色绑定（Seedream / Doubao Seedream）──
# las-xxx 格式的 Key 属于火山 LAS 服务，必须用 LAS Operator 端点
# 若使用方舟 Ark Key，则改 BASE_URL 为：https://ark.cn-beijing.volces.com/api/v3
SEEDREAM_API_KEY="las-xxxx"
SEEDREAM_BASE_URL="https://operator.las.cn-beijing.volces.com/api/v1"
IMAGE_PROVIDER="seedream"
# LAS 模型 ID 含版本号后缀；其他可选：doubao-seedream-4-0-250828 / doubao-seedream-5-0-lite-260128
IMAGE_MODEL="doubao-seedream-4-5-251128"

# 官方文档：
# https://www.volcengine.com/docs/6492/2165104
# ── 摄影：图生视频（Seedance / Doubao Seedance）──────────────
SEEDANCE_API_KEY="sk-xxxx"
SEEDANCE_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
VIDEO_PROVIDER="seedance"
VIDEO_MODEL="doubao-seedance-1-0-pro-250528"

# 官方文档：
# https://www.volcengine.com/docs/6561/79818
# ── 声音：角色级 TTS（豆包语音）──────────────────────────────
DOUBAO_TTS_API_KEY="sk-xxxx"
DOUBAO_TTS_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
TTS_PROVIDER="doubao-tts"
TTS_MODEL="doubao-voice-lite-tts"

# 官方文档：
# https://elevenlabs.io/api
# https://elevenlabs.io/docs/capabilities/sound-effects/
# ── 音效：SFX 环境音生成（ElevenLabs，可选）────────────────
# 配置后优先使用 ElevenLabs；未配置时回退到 MiniMax/Fallback SFX 方案
# ELEVENLABS_API_KEY="sk-xxxx"

# ── 并发控制 ──────────────────────────────────────────────
# 建议 2~3，避免触发 API 限流（429）
GENERATION_CONCURRENCY="2"
