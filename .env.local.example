# ── 数据库 ────────────────────────────────────────────────
DATABASE_URL="file:./public/workspace/database.db"

# ── 大脑：剧本与分镜逻辑（DeepSeek V4 Pro）─────────────────
DEEPSEEK_API_KEY="sk-xxxx"
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
DEEPSEEK_MODEL="deepseek-v4-pro"

# 视觉质检 Agent 使用的模型（支持图片输入，留空则使用 DEEPSEEK）
# VISION_QA_MODEL="deepseek-chat"

# ── 美术：图片生成与角色绑定（即梦 Seedream V5）────────────
SEEDREAM_API_KEY="sk-xxxx"
SEEDREAM_BASE_URL="https://api.seedream.io/v1"
IMAGE_MODEL="seedream-v5.0"

# ── 摄影：图生视频与物理引擎（海螺 Hailuo-02）──────────────
VIDEO_API_KEY="sk-xxxx"
VIDEO_MODEL="hailuo-02"
VIDEO_BASE_URL="https://api.minimaxi.chat/v1"

# 备用视频引擎（可灵）
# KLING_API_KEY="sk-xxxx"
# KLING_BASE_URL="https://api.klingai.com/v1"

# VIDEO_PROVIDER="hailuo"   # 切换为 kling 使用可灵

# ── 声音：TTS 台词情绪（MiniMax Speech-01）─────────────────
TTS_API_KEY="sk-xxxx"
TTS_BASE_URL="https://api.minimaxi.chat/v1"
TTS_MODEL="minimax-speech-01"

# ── 音效：SFX 环境音生成（ElevenLabs，可选）────────────────
# 未配置时自动回退到 MiniMax TTS 生成音效标签
# SFX_API_KEY="sk-xxxx"

# ── 并发控制 ──────────────────────────────────────────────
# 建议 2~3，避免触发 API 限流（429）
GENERATION_CONCURRENCY="2"
