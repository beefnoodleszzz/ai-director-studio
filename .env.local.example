DATABASE_URL="file:./workspace/database.db"

# ── 文本生成：OpenAI 兼容接口 / GPT-5.4 ─────────────────────
# 当前项目默认按 chat/completions 方式请求
TEXT_API_KEY="sk-xxxx"
TEXT_BASE_URL="https://sakura886.site/v1"
TEXT_MODEL="gpt-5.4"
TEXT_API_STYLE="chat-completions"

# ── 图片生成：Sakura 网关 / pro/gpt-image-2 ─────────────────
IMAGE_API_KEY="sk-xxxx"
IMAGE_BASE_URL="https://sakura886.site/v1"
IMAGE_PROVIDER="sakura"
IMAGE_MODEL="pro/gpt-image-2"
IMAGE_SIZE="1024x1024"
IMAGE_ASPECT_RATIO="9:16"

# ── 视频生成：后续可调整 ────────────────────────────────────
SEEDANCE_API_KEY="sk-xxxx"
SEEDANCE_BASE_URL="https://operator.las.cn-beijing.volces.com/api/v1"
VIDEO_PROVIDER="seedance"
VIDEO_MODEL="doubao-seedance-1-0-pro-250528"

# ── 语音生成：后续可调整 ────────────────────────────────────
DOUBAO_TTS_API_KEY="sk-xxxx"
DOUBAO_TTS_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
TTS_PROVIDER="doubao-tts"
TTS_MODEL="doubao-voice-lite-tts"

# ── 运行参数 ────────────────────────────────────────────────
GENERATION_CONCURRENCY="2"
APP_BASE_URL="http://localhost:3000"
