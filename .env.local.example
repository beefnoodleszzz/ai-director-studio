# 数据库（SQLite，相对于项目根目录）
DATABASE_URL="file:./dev.db"

# 剧本大脑 - DeepSeek
DEEPSEEK_API_KEY="sk-xxxx"
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
DEEPSEEK_MODEL="deepseek-chat"

# 视觉资产 - 字节即梦 Seedream（图像生成）
SEEDREAM_API_KEY="sk-xxxx"
SEEDREAM_BASE_URL="https://api.seedream.io/v1"

# 动态引擎 - 可灵（图生视频）
KLING_API_KEY="sk-xxxx"
KLING_BASE_URL="https://api.klingai.com/v1"

# 动态引擎备选 - 海螺（图生视频）
HAILUO_API_KEY="sk-xxxx"
HAILUO_BASE_URL="https://api.minimaxi.chat/v1"

# 视频生成引擎选择：kling 或 hailuo
VIDEO_PROVIDER="kling"

# 声音设计 - MiniMax Speech（TTS）
TTS_API_KEY="sk-xxxx"
TTS_BASE_URL="https://api.minimaxi.chat/v1"
TTS_MODEL="speech-02-hd"

# 图像生成并发数（建议 2~3，避免被限流）
GENERATION_CONCURRENCY="2"
